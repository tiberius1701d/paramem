# Allowlist: small anonymized test fixtures that exercise the PDF chunker.
!tests/fixtures/*.pdf

# Test-fixture sandbox: tests/fixtures/server.yaml routes paths.* into here so
# tests that don't override paths land in a gitignored location instead of
# polluting the live store. Per-run subdirs are auto-created by ConsolidationLoop.
tests/fixtures/sandbox/

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.pdf
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz

# Server runtime (logs may contain conversation content)
logs/
*.pid

# User-specific tool definitions (created from tools.yaml.example)
configs/tools.yaml

# Operator-local server config (created from server.yaml.example)
/configs/server.yaml

# HA data (adapters, registry, sessions — regenerated by server)
data/ha/
data/ha.pre-*/
data/ha.*/
data/ha-*/

# Session data (regenerated by scripts)
data/sessions/*.json

# Throwaway prod/test snapshots + pre-probe checkpoints (hold real speaker_profiles.json — never stage)
data/*_snapshot_*/
data/preprobe_ckpt_*/

# Runtime control-plane state (incidents, run_status, consolidation_retry — regenerated by server)
data/state/
scripts/ha_voice_satellite_office.yaml

# HA config files (contain personal location data)
ha_jarvis_prompt.txt
ha_jarvis_tools.yaml
ha_music_control_script.yaml
ha_get_weather_worldwide.yaml
ha_automations/

# Claude Code local settings
.claude/

# Operator-local document ingest staging (raw documents + extracted text)
ingest/

# Orchestrator-internal working docs (handovers, alignment plans, session logs)
.agent/

# Internal design plans and follow-up specs (not for public repo)
docs/
# Allowlist: anonymized text/markdown fixtures used by chunker + CLI tests.
!tests/fixtures/docs/
f52_spec.md
f52_architecture.md
REVIEW_REPORT.md

# Calibration variant prompts (operator-side iteration; never committed).
# The calibrate_prompts.py tool reads these via --prompt-prefix calib_;
# production prompts (no prefix) stay tracked.
configs/prompts/calib_*.txt

# Calibration tool dump dirs.
data/ha/debug/calibration/

# Experiment-local fixtures (binary weights, plaintext reference data).
# Stable baselines captured from production cycles for reproducibility;
# regenerable from a fresh consolidate cycle if lost.
experiments/fixtures/

# MagicMock-named directory leakage. Several tests mock snapshot_dir_for(...)
# or config.paths.data with a bare MagicMock; production code that calls
# .mkdir(parents=True, exist_ok=True) on the mocked return value reaches the
# filesystem with str(MagicMock()) as the path, creating directories like
# "<MagicMock name='mock.snapshot_dir_for().__truediv__()' id='...'>" (repr
# form) or "MagicMock/mock.paths.data.__truediv__()" (the durable-state
# record_last_run/record_incident path form). Fixing every test to use
# spec=Path mocks is a separate pass.
<MagicMock*
MagicMock/
